#Chance that a cluster cell becomes an island anchor. Lower values create larger sky gaps.
# Default: 0.4
# Range: 0.01 ~ 1.0
islandDensity = 0.4
#Minimum horizontal island radius in blocks.
# Default: 24
# Range: 8 ~ 128
minIslandRadius = 24
#Maximum horizontal island radius in blocks.
# Default: 75
# Range: 8 ~ 500
maxIslandRadius = 75
#How island radius sizes are selected. RANDOM preserves global min/max behavior, SPECIFIC uses small/medium/large bands.
#Allowed Values: RANDOM, SPECIFIC
islandSizeMode = "RANDOM"
#Specific mode: minimum radius for small islands.
# Default: 24
# Range: 8 ~ 500
smallIslandMinRadius = 24
#Specific mode: maximum radius for small islands.
# Default: 41
# Range: 8 ~ 500
smallIslandMaxRadius = 41
#Specific mode: spawn weight for small islands.
# Default: 0.34
# Range: 0.0 ~ 1.0
smallIslandWeight = 0.34
#Specific mode: minimum radius for medium islands.
# Default: 42
# Range: 8 ~ 500
mediumIslandMinRadius = 42
#Specific mode: maximum radius for medium islands.
# Default: 58
# Range: 8 ~ 500
mediumIslandMaxRadius = 58
#Specific mode: spawn weight for medium islands.
# Default: 0.33
# Range: 0.0 ~ 1.0
mediumIslandWeight = 0.33
#Specific mode: minimum radius for large islands.
# Default: 59
# Range: 8 ~ 500
largeIslandMinRadius = 59
#Specific mode: maximum radius for large islands.
# Default: 75
# Range: 8 ~ 500
largeIslandMaxRadius = 75
#Specific mode: spawn weight for large islands.
# Default: 0.33
# Range: 0.0 ~ 1.0
largeIslandWeight = 0.33
#Minimum Y for island centers.
# Default: 20
# Range: -32 ~ 320
minIslandY = 20
#Maximum Y for island centers.
# Default: 170
# Range: -16 ~ 320
maxIslandY = 170
#Relative weight of the uncommon low-island height band.
# Default: 0.15
# Range: 0.0 ~ 10.0
lowBandWeight = 0.15
#Relative weight of the dominant mid/high island height band.
# Default: 0.75
# Range: 0.0 ~ 10.0
midHighBandWeight = 0.75
#Relative weight of the rare very-high island height band.
# Default: 0.1
# Range: 0.0 ~ 10.0
veryHighBandWeight = 0.1
#Center offset applied to the low-island band within the configured vertical envelope.
# Default: -18
# Range: -96 ~ 96
lowBandCenterOffset = -18
#Center offset applied to the very-high island band within the configured vertical envelope.
# Default: 12
# Range: -96 ~ 96
veryHighBandCenterOffset = 12
#Average spacing between island clusters in blocks.
# Default: 96
# Range: 32 ~ 2000
clusterSpacing = 96
#Cluster spacing mode. CONSISTENT uses fixed spacing. DYNAMIC picks deterministic per-world spacing from min/max.
#Allowed Values: CONSISTENT, DYNAMIC
clusterSpacingMode = "CONSISTENT"
#Dynamic spacing mode: minimum cluster spacing in blocks.
# Default: 96
# Range: 32 ~ 2000
minClusterSpacing = 96
#Dynamic spacing mode: maximum cluster spacing in blocks.
# Default: 96
# Range: 32 ~ 2000
maxClusterSpacing = 96
#Multiplier for island top-surface height variation. Higher values create rougher, less flat tops.
# Default: 1.0
# Range: 0.0 ~ 40.0
terrainReliefScale = 1.0
#Whether the classic island archetype is allowed to spawn.
classicArchetypeEnabled = true
#Relative spawn weight for the classic island archetype.
# Default: 1.0
# Range: 0.0 ~ 10.0
classicArchetypeWeight = 1.0
#Whether the bowl/crater island archetype is allowed to spawn.
bowlCraterArchetypeEnabled = true
#Relative spawn weight for the bowl/crater island archetype.
# Default: 1.0
# Range: 0.0 ~ 10.0
bowlCraterArchetypeWeight = 1.0
#Whether the crescent island archetype is allowed to spawn.
crescentArchetypeEnabled = true
#Relative spawn weight for the crescent island archetype.
# Default: 1.0
# Range: 0.0 ~ 10.0
crescentArchetypeWeight = 1.0
#Whether the terrace island archetype is allowed to spawn.
terraceArchetypeEnabled = true
#Relative spawn weight for the terrace island archetype.
# Default: 1.0
# Range: 0.0 ~ 10.0
terraceArchetypeWeight = 1.0
#Whether to fill an optional ocean layer below the sky islands.
oceanEnabled = false
#Maximum Y level filled by the optional ocean layer when ocean generation is enabled.
# Default: 0
# Range: -64 ~ 320
oceanLevelY = 0
#Whether to shape an ocean floor beneath the ocean surface using deterministic noise.
oceanFloorNoiseEnabled = true
#Base depth below ocean level for the ocean floor shape.
# Default: 18
# Range: 0 ~ 128
oceanFloorBaseOffset = 18
#Vertical amplitude of ocean floor noise in blocks.
# Default: 10
# Range: 0 ~ 128
oceanFloorNoiseAmplitude = 10
#Horizontal scale of ocean floor noise. Lower values make broader features.
# Default: 0.05
# Range: 0.001 ~ 1.0
oceanFloorNoiseScale = 0.05
#Minimum depth below ocean level for ocean floor clamping.
# Default: 8
# Range: 1 ~ 128
oceanFloorMinDepth = 8
#Maximum depth below ocean level for ocean floor clamping.
# Default: 40
# Range: 1 ~ 128
oceanFloorMaxDepth = 40
#Fluid block used by the optional ocean layer.
#Allowed Values: WATER, LAVA
oceanBlockType = "WATER"
#How far below a structure footprint to scan for support.
# Default: 48
# Range: 1 ~ 256
supportCheckDepth = 48
#Grid size used to sample support across the structure footprint.
# Default: 5
# Range: 1 ~ 15
supportSampleGridSize = 5
#Required fraction of supported samples for a structure to be accepted.
# Default: 0.6
# Range: 0.0 ~ 1.0
supportThreshold = 0.6
#Required fraction of supported samples for surface-sky structures.
# Default: 0.42
# Range: 0.0 ~ 1.0
surfaceSkySupportThreshold = 0.42
#Required fraction of supported samples for small sky structures.
# Default: 0.32
# Range: 0.0 ~ 1.0
smallSkySupportThreshold = 0.32
#Inset ratio used to shrink support footprints for larger sky-surface structures.
# Default: 0.18
# Range: 0.0 ~ 0.49
surfaceSkyFootprintInsetRatio = 0.18
#Inset ratio used to shrink support footprints for smaller sky structures.
# Default: 0.28
# Range: 0.0 ~ 0.49
smallSkyFootprintInsetRatio = 0.28
#How many chunks outward to search for an island-top candidate for larger sky-surface structures.
# Default: 3
# Range: 0 ~ 12
surfaceSkySearchRadiusChunks = 3
#How many chunks outward to search for an island-top candidate for smaller sky structures.
# Default: 8
# Range: 0 ~ 12
smallSkySearchRadiusChunks = 8
#Minimum number of stable top-surface samples required for a larger sky-surface structure candidate.
# Default: 12
# Range: 1 ~ 64
surfaceSkyMinStableTopCells = 12
#Minimum number of stable top-surface samples required for a smaller sky structure candidate.
# Default: 5
# Range: 1 ~ 64
smallSkyMinStableTopCells = 5
#Vertical offset applied when aligning larger sky-surface structures to an island top.
# Default: 1
# Range: -16 ~ 32
surfaceSkyTopOffset = 1
#Vertical offset applied when aligning smaller sky structures to an island top.
# Default: 1
# Range: -16 ~ 32
smallSkyTopOffset = 1
#Block step size used when sweeping local placement sites for larger sky-surface structures.
# Default: 8
# Range: 1 ~ 32
surfaceSkyLocalSearchStepBlocks = 8
#Block step size used when sweeping local placement sites for smaller sky structures.
# Default: 4
# Range: 1 ~ 32
smallSkyLocalSearchStepBlocks = 4
#Maximum local offset radius in blocks tested across an island top for larger sky-surface structures.
# Default: 24
# Range: 0 ~ 96
surfaceSkyLocalSearchRadiusBlocks = 24
#Maximum local offset radius in blocks tested across an island top for smaller sky structures.
# Default: 20
# Range: 0 ~ 96
smallSkyLocalSearchRadiusBlocks = 20
#Required grounded-base sample ratio for larger sky-surface structures after relocation.
# Default: 0.7
# Range: 0.0 ~ 1.0
surfaceSkyGroundedSampleThreshold = 0.7
#Required grounded-base sample ratio for smaller sky structures after relocation.
# Default: 0.75
# Range: 0.0 ~ 1.0
smallSkyGroundedSampleThreshold = 0.75
#Maximum gap in blocks allowed between the relocated structure base and solid terrain for larger sky-surface structures.
# Default: 1
# Range: 0 ~ 8
surfaceSkyMaxGroundGapBlocks = 1
#Maximum gap in blocks allowed between the relocated structure base and solid terrain for smaller sky structures.
# Default: 1
# Range: 0 ~ 8
smallSkyMaxGroundGapBlocks = 1
#Minimum island preview radius required before a larger sky-surface structure can consider an island as a grounded host.
# Default: 26
# Range: 0 ~ 128
surfaceSkyMinHostIslandRadius = 26
#Minimum island preview radius required before a smaller sky structure can consider an island as a grounded host.
# Default: 22
# Range: 0 ~ 128
smallSkyMinHostIslandRadius = 22
#Minimum stable top-cell count required before a larger sky-surface structure considers an island a qualified grounded host.
# Default: 10
# Range: 1 ~ 64
surfaceSkyMinHostStableTopCells = 10
#Minimum stable top-cell count required before a smaller sky structure considers an island a qualified grounded host.
# Default: 7
# Range: 1 ~ 64
smallSkyMinHostStableTopCells = 7
#Reserved toggle for future near-miss promotion of uncategorized surface structures. Disabled by default.
defaultNearMissFallbackEnabled = false
#Whether Sky Archipelago custom structure placement/support rules are enabled.
customStructureRulesEnabled = true
#Whether satellite/spire companion islands generate around anchor islands.
clusterCompanionIslandsEnabled = true
#Whether anchor islands use extra fragmentation features that create small outcroppings/debris.
anchorFragmentationEnabled = true
#Island interior below or at this Y uses deepslate substrate.
# Default: 16
# Range: -64 ~ 320
deepslateStartY = 16
#Whether strongholds can retry placement by injecting a temporary host island after initial support failure.
strongholdHostIslandEnabled = true
#How many nearest strongholds to origin are eligible for host-island retry.
# Default: 8
# Range: 1 ~ 128
strongholdHostIslandClosestN = 8
#Minimum radius for injected stronghold host islands.
# Default: 192
# Range: 8 ~ 256
strongholdHostIslandRadiusMin = 192
#Maximum radius for injected stronghold host islands.
# Default: 256
# Range: 8 ~ 256
strongholdHostIslandRadiusMax = 256
#Structures that may generate in unsupported air positions.
#Examples: modid:sky_temple, modid:airship_wreck, modid:floating_platform
skyStructureWhitelist = ["shellbound_for_airship:airship_ship1", "shellbound_for_airship:airship_ship2", "shellbound_for_airship:airship_ship3", "shellbound_for_airship:airship_ship4", "shellbound_for_airship:airship_ship5", "shellbound_for_airship:airship_ship6", "shellbound_for_airship:airship_ship7", "shellbound_for_airship:airship_ship8", "shellbound_for_airship:airship_ship9", "shellbound_for_airship:airship_ship10", "sky_whale_ship:whale", "sky_whale_ship:whaleship", "sky_whale_ship:whalelight", "sky_whale_ship:whalearena", "mostructures:the_castle_in_the_sky", "create_structures_arise:pillagersteampunkairship"]
#Structures to skip entirely before placement validation.
#Leave empty by default so future special handling can still be added later.
skyStructureDenylist = []
#Optional per-structure placement categories in the form modid:structure=CATEGORY.
#Supported categories: DEFAULT, SURFACE_SKY, SMALL_SKY, HAMLET_SKY, DEFERRED.
skyStructureCategoryOverrides = ["minecraft:pillager_outpost=SURFACE_SKY", "minecraft:ruined_portal_desert=SMALL_SKY", "valhelsia_structures:desert_house=SMALL_SKY", "repurposed_structures:outpost_oak=SURFACE_SKY", "valhelsia_structures:player_house=SMALL_SKY", "valhelsia_structures:forge=SMALL_SKY", "valhelsia_structures:tower_ruin=SMALL_SKY", "valhelsia_structures:big_tree=SMALL_SKY", "mostructures:villager_tower=SURFACE_SKY", "mostructures:villager_market=SURFACE_SKY", "sky_archipelago:sky_hamlet_plains=HAMLET_SKY", "sky_archipelago:sky_hamlet_desert=HAMLET_SKY", "sky_archipelago:sky_hamlet_savanna=HAMLET_SKY", "sky_archipelago:sky_hamlet_snowy=HAMLET_SKY", "sky_archipelago:sky_hamlet_taiga=HAMLET_SKY"]
